{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "LabServer": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LabServer",
      "options": {
        "baseURL": "{env:LAB_SERVER_URL}"
      },
      "models": {
        "qwen3.5-flash": {
          "name": "qwen3.5-flash",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },
  // 插件
  "plugin": [
    "file:///usr/lib/opencode/plugins/opencode-notifier", // 需安装 opencode-notifier
    "file:///usr/lib/opencode/plugins/opencode-md-table-formatter" // 自动格式化 md 表格
  ],
  // 默认 agent
  "default_agent": "copilot",
  // mcp server
  "mcp": {
    "arch-linux": {
      "type": "local",
      "timeout": 30000, // 30s
      "command": [
        "uvx",
        "arch-ops-server"
      ]
    },
    "open-websearch": {
      "type": "local",
      "timeout": 30000,
      "command": [
        "npx",
        "-y",
        "open-websearch@latest"
      ],
      "environment": {
        "DEFAULT_SEARCH_ENGINE": "brave"
      }
    }
  },
  // 工具使用权限
  "permission": {
    "bash": "deny",
    "codesearch": "deny",
    "edit": "deny",
    "read": "deny",
    "grep": "deny",
    "glob": "deny",
    "lsp": "deny",
    "skill": "deny",
    "task": "deny",
    "todoread": "deny",
    "todowrite": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "question": "deny"
  },
  // 禁用自动更新, 仅从 AUR 更新
  "autoupdate": false,
  // 上下文自动压缩
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384
  },
  // 忽略常变动的目录
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "agent": {
    "copilot": {
      "permission": {
        "bash": "ask",
        "read": "allow",
        "grep": "allow",
        "skill": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        // "webfetch": "allow",
        "question": "allow"
      }
    },
    "marxist": {},
    "slidev": {
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "skill": "allow",
        "question": "allow"
      }
    },
    // 默认 agent 的提示词写得稀烂
    // 全部禁用
    "build": {
      "disable": true
    },
    "plan": {
      "mode": "primary",
      "disable": true,
      "permission": {
        "skill": "allow"
      }
    }
  }
}