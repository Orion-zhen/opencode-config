{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "LabServer": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LabServer",
      "options": {
        "baseURL": "{env:LAB_SERVER_URL}"
      },
      "models": {
        "qwen3.5-plus": {
          "name": "qwen3.5-plus",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "qwen3.5-plus-codex": {
          "name": "qwen3.5-plus-codex",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },
  // 插件
  "plugin": [
    "file:///usr/lib/opencode/plugins/opencode-notifier", // 需安装 opencode-notifier
    "file:///usr/lib/opencode/plugins/opencode-md-table-formatter", // 自动格式化 md 表格
    "file:///usr/lib/opencode/plugins/opencode-dynamic-context-pruning", // 需安装 opencode-dynamic-context-pruning
  ],
  // 默认 agent
  "default_agent": "copilot",
  // mcp server
  "mcp": {
    "open-websearch": {
      "type": "local",
      "timeout": 30000,
      "command": [
        "npx",
        "-y",
        "open-websearch@latest"
      ],
      "environment": {
        "DEFAULT_SEARCH_ENGINE": "brave"
      }
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    }
  },
  "lsp": {},
  // 工具使用权限
  "permission": {
    "*": "deny",
    "doom_loop": "ask",
    "external_directory": "ask"
  },
  // 禁用自动更新, 仅从 AUR 更新
  "autoupdate": false,
  // 上下文自动压缩
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384
  },
  // 忽略常变动的目录
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "agent": {
    "empty": {
      "permission": {
        "read": "allow"
      }
    },
    "professor": {
      "permission": {
        "task": {
          "*": "deny",
          "repo-navigator": "allow",
          "code-retriever": "allow",
          "damn-editor": "allow"
        },
        "write": "allow",
        "read": "allow"
      }
    },
    "executor": {
      "permission": {
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "repo-navigator": "allow",
          "code-retriever": "allow",
          "typewriter": "allow",
          "verifier": "allow",
        },
        "read": "allow"
      }
    },
    "repo-navigator": {
      "permission": {
        "read": "allow"
      }
    },
    "code-retriever": {
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "damn-editor": {
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "typewriter": {
      "permission": {
        "read": "allow",
        "grep": "allow",
        "edit": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        "deepwiki_ask_question": "allow"
      }
    },
    "verifier": {
      "permission": {
        "read": "allow",
        "grep": "allow",
        "bash": "allow"
      }
    },
    "copilot": {
      "permission": {
        "websearch": "allow",
        "open-websearch*": "allow",
        "bash": "ask",
        "read": "allow",
        "skill": {
          "*": "allow",
          "slidev*": "deny"
        },
        "question": "allow"
      }
    },
    "marxist": {},
    "slidev": {
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "skill": {
          "*": "deny",
          "slidev*": "allow"
        },
        "question": "allow"
      }
    },
    // 默认 agent 的提示词写得稀烂
    // 全部禁用
    "build": {
      "disable": true
    },
    "plan": {
      "mode": "primary",
      "disable": true,
      "permission": {
        "skill": "allow"
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}